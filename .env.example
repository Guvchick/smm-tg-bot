# ============================================================
# SMM Telegram Bot environment
# Скопируйте файл в .env и заполните реальные значения:
# cp .env.example .env
# ============================================================


# ----------------------------
# App / HTTP
# ----------------------------

# Окружение приложения: dev, stage или prod.
APP_ENV=dev

# Уровень логов бота: debug, info, warn, error.
LOG_LEVEL=info

# Локальный адрес HTTP-сервера.
# На этот порт Caddy будет проксировать webhook-запросы платежек.
HTTP_ADDR=:8080

# Публичный HTTPS-адрес бота без слэша в конце.
# Используется для callback/webhook URL платежных систем.
# В продакшене обязательно должен быть https://, иначе вебхуки платежек не пройдут SSL-проверку.
PUBLIC_BASE_URL=https://bot.example.com

# Локальный порт, на который docker-compose публикует HTTP API бота только на 127.0.0.1.
# Его нужно прокинуть через уже существующий SSL reverse proxy на сервере.
BOT_HOST_PORT=18080


# ----------------------------
# Caddy reverse proxy
# ----------------------------

# Важно: на одном сервере только один процесс может слушать 80/443.
# Если 80/443 уже заняты Nextcloud AIO или другим reverse proxy, НЕ включайте профиль caddy.
# Вместо этого прокиньте https://bot.example.com на http://127.0.0.1:18080 в уже существующем proxy.

# Домен, который будет слушать Caddy, если вы запускаете профиль caddy.
# CADDY_DOMAIN=bot.example.com
CADDY_DOMAIN=bot.example.com

# Куда Caddy проксирует запросы.
# Если Caddy запущен в этом compose, оставьте:
CADDY_UPSTREAM=bot:8080

# Порты Caddy на хосте.
# По умолчанию стоят НЕ 80/443, чтобы не конфликтовать с Nextcloud AIO.
# Для настоящего SSL напрямую через Caddy нужны 80/443, но только если они свободны.
CADDY_HTTP_PORT=8081
CADDY_HTTPS_PORT=8444

# Запуск Caddy, только если порты свободны:
# docker compose --profile caddy up -d --build


# ----------------------------
# Cloudflare Tunnel
# ----------------------------

# Рекомендуемый вариант, если 80/443 уже заняты Nextcloud AIO.
# Создайте Tunnel в Cloudflare Zero Trust и добавьте Public Hostname:
# wh-smm.kys-paw.life -> http://bot:8080
# В docker-compose для сервиса bot задан network alias "bot", чтобы cloudflared
# стабильно резолвил этот адрес внутри Docker-сети.
# Потом вставьте сюда token tunnel-коннектора.
CLOUDFLARE_TUNNEL_TOKEN=

# Запуск tunnel-коннектора:
# docker compose --profile tunnel up -d cloudflared


# ----------------------------
# Telegram
# ----------------------------

# required: токен Telegram-бота из @BotFather.
TELEGRAM_BOT_TOKEN=123456:replace-me

# required: Telegram ID администраторов через запятую.
# Узнать свой ID можно через @userinfobot.
ADMIN_IDS=111111111,222222222

# optional: ID группы/чата для уведомлений о заказах и оплатах.
# Для супергрупп обычно начинается с -100.
ADMIN_GROUP_ID=-1001234567890

# optional: ID группы/чата, куда бот будет отправлять архивы автобэкапов.
BACKUP_GROUP_ID=-1001234567890

# optional: ID топиков внутри ADMIN_GROUP_ID/BACKUP_GROUP_ID.
# Если оставить 0/пусто, бот отправит сообщение просто в группу.
# ID топика можно получить из ссылки на сообщение в топике:
# https://t.me/c/CHAT_ID/TOPIC_ID/MESSAGE_ID
ADMIN_TOPIC_GENERAL_ID=0
ADMIN_TOPIC_ORDERS_ID=0
ADMIN_TOPIC_PAYMENTS_ID=0
ADMIN_TOPIC_BACKUPS_ID=0
ADMIN_TOPIC_SUPPORT_ID=0


# ----------------------------
# Support
# ----------------------------

# Текст раздела поддержки в боте.
SUPPORT_TEXT=Напишите обращение, и администратор ответит вам как можно быстрее.

# optional: ссылка на поддержку, если есть отдельный чат/бот/оператор.
SUPPORT_URL=

# optional: username оператора без @ или с @.
SUPPORT_USERNAME=

# Стартовый бонус новым пользователям в рублях.
# Для старой базы существующие пользователи помечаются как уже получившие бонус.
NEW_USER_BONUS_RUB=10


# ----------------------------
# PostgreSQL
# ----------------------------

# Пароль, с которым создается PostgreSQL при первом создании volume.
# Важно: если volume уже существует, изменение этой переменной НЕ меняет пароль внутри БД.
POSTGRES_PASSWORD=postgres

# required для локального запуска без Docker: строка подключения к PostgreSQL.
# В docker-compose бот получает DATABASE_URL автоматически из POSTGRES_PASSWORD,
# чтобы пароль Postgres и пароль бота не разъезжались.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/smm_bot?sslmode=disable
# Если запускаете бота локально на хосте через go run, используйте:
# DATABASE_URL=postgres://postgres:postgres@localhost:15432/smm_bot?sslmode=disable

# Если видите "password authentication failed", значит пароль в DATABASE_URL
# не совпадает с паролем, сохраненным в старом Docker volume PostgreSQL.
# Варианты:
# 1. Если данные не нужны: docker compose down -v && docker compose up -d --build
# 2. Если данные нужны: зайти в Postgres и выполнить ALTER USER postgres WITH PASSWORD 'новый_пароль';

# Лимит подключений бота к PostgreSQL.
# Важно для небольших VPS: не ставьте огромные значения.
POSTGRES_MAX_CONNS=5
POSTGRES_MIN_CONNS=0

# Локальный порт PostgreSQL на хосте. Публикуется только на 127.0.0.1.
POSTGRES_HOST_PORT=15432


# ----------------------------
# Redis
# ----------------------------

# required: адрес Redis.
# Для docker-compose:
REDIS_ADDR=redis:6379
# Для локального запуска бота на хосте:
# REDIS_ADDR=localhost:16379

# optional: переопределение REDIS_ADDR именно для docker-compose сервиса bot.
# Обычно не нужно менять.
BOT_REDIS_ADDR=redis:6379

# Локальный порт Redis на хосте. Публикуется только на 127.0.0.1.
REDIS_HOST_PORT=16379

# optional: пароль Redis, если включена авторизация.
REDIS_PASSWORD=

# optional: номер Redis DB.
REDIS_DB=0


# ----------------------------
# SocRocket / SMM API
# ----------------------------

# required: endpoint SocRocket API.
SOC_ROCKET_API_URL=https://soc-rocket.ru/api/v2/

# required: API key из кабинета SocRocket.
SOC_ROCKET_API_KEY=replace-me

# Наценка по умолчанию в процентах.
# Можно переопределять для отдельных услуг командой /setmarkup.
DEFAULT_MARKUP_PERCENT=25


# ----------------------------
# Payments: Platega
# ----------------------------

# Включить/выключить Platega в меню бота и webhook.
# false = кнопка пропадет, webhook /webhooks/platega будет отклоняться.
PLATEGA_ENABLED=true

# Endpoint создания платежа Platega.
PLATEGA_API_URL=https://app.platega.io/api/v1/transaction/process

# Platega выдает MerchantId и API key/Secret в личном кабинете.
# Эти же значения используются для базовой проверки webhook.
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=


# ----------------------------
# Payments: Pally
# ----------------------------

# Включить/выключить Pally.
PALLY_ENABLED=true

# Endpoint создания счета Pally.
PALLY_API_URL=https://pal24.pro/api/v1/bill/create

# Токен мерчанта Pally.
PALLY_TOKEN=

# ID магазина Pally.
PALLY_SHOP_ID=

# optional: отдельный секрет подписи webhook, если он отличается от PALLY_TOKEN.
# Если пусто, код использует PALLY_TOKEN.
PALLY_WEBHOOK_SECRET=


# ----------------------------
# Payments: Heleket
# ----------------------------

# Включить/выключить Heleket.
HELEKET_ENABLED=true

# Endpoint создания платежа Heleket.
HELEKET_API_URL=https://api.heleket.com/v1/payment

# Payment API key для создания платежей и проверки webhook signature.
HELEKET_PAYMENT_KEY=

# Merchant UUID/ID из кабинета Heleket.
HELEKET_MERCHANT_ID=


# ----------------------------
# Payments: CryptoBot
# ----------------------------

# Включить/выключить CryptoBot / Crypto Pay.
CRYPTOBOT_ENABLED=true

# Crypto Pay API token из приложения в @CryptoBot.
CRYPTOBOT_TOKEN=

# Для продакшена: https://pay.crypt.bot
# Для тестнета, если используете @CryptoTestnetBot, замените на тестовый base URL.
CRYPTOBOT_BASE_URL=https://pay.crypt.bot


# ----------------------------
# Bonuses / Referrals
# ----------------------------

# Процент бонуса рефереру от успешного пополнения приглашенного пользователя.
REFERRAL_PERCENT=5


# ----------------------------
# Background jobs
# ----------------------------

# Как часто проверять статусы активных заказов в SocRocket.
# Можно временно выключить, если БД/провайдер перегружены.
ORDER_SYNC_ENABLED=true
# Минимум в коде: 1m. Рекомендуемо для старта: 5m.
ORDER_SYNC_INTERVAL=5m

# Автоматическая проверка ожидающих платежей.
# Это страховка на случай, если webhook платежки не дошел:
# бот сам проверит счет у провайдера и зачислит оплату без ручной кнопки.
# Сейчас polling реализован для CryptoBot, потому что его API позволяет getInvoices.
PAYMENT_POLL_ENABLED=true
# Минимум в коде: 15s. Рекомендуемо для CryptoBot: 30s.
PAYMENT_POLL_INTERVAL=30s

# Как часто отправлять автобэкап PostgreSQL в BACKUP_GROUP_ID.
# Можно выключить, если pg_dump грузит сервер.
BACKUP_ENABLED=true
# Минимум в коде: 1h.
BACKUP_INTERVAL=24h


# ----------------------------
# Google Sheets
# ----------------------------

# Включить запись заказов и пополнений в Google Sheets.
# Нужно создать service account в Google Cloud и расшарить таблицу на его client_email.
GOOGLE_SHEETS_ENABLED=false

# ID таблицы из URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Вариант 1: путь к JSON-ключу service account внутри контейнера/на сервере.
GOOGLE_SHEETS_CREDENTIALS_FILE=

# Вариант 2: сам JSON-ключ одной строкой вместо файла.
GOOGLE_SHEETS_CREDENTIALS_JSON=

# Названия листов. Если листов нет, бот создаст их сам и проставит заголовки.
GOOGLE_SHEETS_ORDERS_SHEET=orders
GOOGLE_SHEETS_DEPOSITS_SHEET=deposits
